{
  "game": "pacland",
  "_comment": "MAME source: src/mame/namco/pacland.cpp. 6809 #1 (main) memory map. The I/O addresses are the write/read locations the 6809 program uses to talk to the arcade hardware. Each entry is a handler the HAL implements.",
  "io_map": {
    "0x7000":  {"kind": "tilemap_enable",  "handler": "hal_tilemap_enable",    "access": "W", "mame": "PBC -- doesn't seem to be used"},
    "0x7800":  {"kind": "watchdog_reset",  "handler": "hal_watchdog_kick",     "access": "R", "mame": "watchdog reset (RESET generated by CUS34A)"},
    "0x8000":  {"kind": "mcu_reset",       "handler": "hal_mcu_reset",         "access": "W", "mame": "SUBRESET -- reset MCU (latch in CUS34A)"},
    "0x8800":  {"kind": "flip_screen",     "handler": "hal_flip_screen",       "access": "W", "mame": "FLIP -- flip screen (latch in CUS34A)"},
    "0x9000":  {"kind": "banked_rom",      "handler": "hal_bank_switch",       "access": "W", "mame": "main CPU bank-switch write"},
    "0xd000":  {"kind": "sound_wave",      "handler": "hal_sound_wave_write",  "access": "W", "mame": "portion holding the sound wave data"},
    "0xd200":  {"kind": "sound_reg",       "handler": "hal_sound_reg_write",   "access": "W", "mame": "portion holding the sound registers"},
    "0xe000":  {"kind": "irq_enable",      "handler": "hal_irq_enable",        "access": "W", "mame": "main CPU irq enable (data is in A11)"},
    "0xf000":  {"kind": "vblank_irq",      "handler": "hal_vblank_ack",        "access": "R", "mame": "vblank IRQ ack"}
  },
  "memory_map": {
    "0x0000-0x1fff": {"kind": "ram",   "backing": "work_ram_2k"},
    "0x9000-0xbfff": {"kind": "rom",   "backing": "main_6809_banked_rom"},
    "0xc000-0xdfff": {"kind": "rom",   "backing": "main_6809_fixed_rom"},
    "0xe000-0xffff": {"kind": "rom",   "backing": "main_6809_fixed_rom"},
    "0xd000-0xd1ff": {"kind": "ram",   "backing": "sound_wave_ram"},
    "0xd200-0xd3ff": {"kind": "ram",   "backing": "sound_reg_ram"}
  }
}
